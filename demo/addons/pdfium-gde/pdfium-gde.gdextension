[configuration]
entry_symbol = "pdfium_gde_library_init"
compatibility_minimum = "4.5"
reloadable = true

[libraries]
windows.debug.x86_64 = "./windows/pdfium-gde.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "./windows/pdfium-gde.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "./linux/libpdfium-gde.linux.template_debug.x86_64.so"
linux.release.x86_64 = "./linux/libpdfium-gde.linux.template_release.x86_64.so"
macos.debug = "./macos/libpdfium-gde.macos.template_debug.arm64.dylib"
macos.release = "./macos/libpdfium-gde.macos.template_release.arm64.dylib"

[dependencies]
windows.debug.x86_64 = {"./windows/pdfium.dll": ""}
windows.release.x86_64 = {"./windows/pdfium.dll": ""}
linux.debug.x86_64 = {"./linux/libpdfium.so": ""}
linux.release.x86_64 = {"./linux/libpdfium.so": ""}
macos.debug = {"./macos/libpdfium.dylib": ""}
macos.release = {"./macos/libpdfium.dylib": ""}
